{
  "name": "apfx",
  "private": true,
  "version": "1.0.0",
  "description": "APFX Finance Platform — Monorepo",
  "packageManager": "npm@11.1.0",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "type-check": "turbo run type-check"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "turbo": "^2.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "gsap": "^3.14.2",
    "lenis": "^1.3.17",
    "lucide-react": "^0.575.0"
  }
}
