# Backend Environment Variables — Copy to .env and fill in values
# NEVER commit .env to git

# Server
PORT=5000
NODE_ENV=development

# CORS — set to your frontend URL in production
ALLOWED_ORIGIN=http://localhost:3000

# Email (Resend — https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx
CONTACT_EMAIL=support@apfx.com

# Market Data API (e.g. exchangerate-api.com, fixer.io)
MARKET_DATA_API_KEY=your_api_key_here
MARKET_DATA_BASE_URL=https://v6.exchangerate-api.com/v6

# CRM Webhook (optional — HubSpot, Zoho, etc.)
CRM_WEBHOOK_URL=
